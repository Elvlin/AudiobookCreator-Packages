<Window x:Class="AudiobookCreator.UI.ScriptPrepWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Name="RootWindow"
        Title="Prepare Script"
        Width="1200"
        Height="760"
        MinWidth="980"
        MinHeight="640"
        WindowStartupLocation="CenterOwner"
        Background="#F4F6F5">
    <Window.Resources>
        <Style x:Key="PrepSecondaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="Background" Value="#DCE4E0" />
            <Setter Property="BorderBrush" Value="#C9D2CD" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#21312A" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#E7EEEA" />
                                <Setter TargetName="Bg" Property="BorderBrush" Value="#B9C8C1" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#CCD8D1" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bg" Property="Background" Value="#E9EEEB" />
                                <Setter TargetName="Bg" Property="BorderBrush" Value="#D7DEDA" />
                                <Setter Property="Foreground" Value="#8A9790" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="PrepIconButtonStyle" TargetType="Button" BasedOn="{StaticResource PrepSecondaryButtonStyle}">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="13" />
        </Style>
        <Style x:Key="PrepMiniButtonStyle" TargetType="Button" BasedOn="{StaticResource PrepSecondaryButtonStyle}">
            <Setter Property="Height" Value="30" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="FontSize" Value="13" />
        </Style>
        <Style x:Key="PrepChipButtonStyle" TargetType="Button" BasedOn="{StaticResource PrepSecondaryButtonStyle}">
            <Setter Property="Height" Value="26" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Background" Value="#EEF3F0" />
            <Setter Property="BorderBrush" Value="#D7E0DB" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                    <Setter Property="Background" Value="#5C846B" />
                    <Setter Property="BorderBrush" Value="#4F7D63" />
                    <Setter Property="Foreground" Value="White" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="PartTextEditorStyle" TargetType="TextBox">
            <Setter Property="MinHeight" Value="70" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="Background" Value="#FAFCFB" />
            <Setter Property="BorderBrush" Value="#D7E0DB" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="AcceptsReturn" Value="True" />
            <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="IsReadOnly" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="EditorBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="EditorBorder" Property="BorderBrush" Value="#4F7D63" />
                                <Setter TargetName="EditorBorder" Property="Background" Value="#FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="EditorBorder" Property="BorderBrush" Value="#B8C7BF" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.65" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock x:Name="SourceFileText" FontSize="15" FontWeight="SemiBold" Foreground="#1F2723" />
                <TextBlock x:Name="ScriptStatusText" Margin="0,4,0,0" Foreground="#52615A" />
                <StackPanel x:Name="LlmProgressPanel" Orientation="Vertical" Margin="0,6,0,0" Visibility="Collapsed">
                    <ProgressBar x:Name="LlmProgressBar" Height="8" Minimum="0" Maximum="100" Value="0" />
                    <TextBlock x:Name="LlmProgressText" Margin="0,4,0,0" Foreground="#4F7D63" Text="" />
                </StackPanel>
            </StackPanel>
            <Button x:Name="AutoPrepareButton" Grid.Column="1" Margin="12,0,0,0" Style="{StaticResource PrepSecondaryButtonStyle}" Content="Auto Prepare (LLM)" Click="AutoPrepareButton_OnClick" />
            <Button x:Name="ResplitButton" Grid.Column="2" Margin="8,0,0,0" Style="{StaticResource PrepSecondaryButtonStyle}" Content="Re-split" Click="ResplitButton_OnClick" />
            <Button x:Name="RegenerateInstructionsButton" Grid.Column="3" Margin="8,0,0,0" Style="{StaticResource PrepSecondaryButtonStyle}" Content="Regenerate Instructions" Click="RegenerateInstructionsButton_OnClick" />
            <Button x:Name="LocalServerToggleButton" Grid.Column="4" Margin="8,0,0,0" Style="{StaticResource PrepSecondaryButtonStyle}" Content="Start LLM Server" Click="LocalServerToggleButton_OnClick" Visibility="Collapsed" />
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="1.02*" MinWidth="280" />
            </Grid.ColumnDefinitions>

            <Border x:Name="PartEditorBorder"
                    Grid.Column="0"
                    Margin="0,0,12,0"
                    Background="White"
                    BorderBrush="#E1E6E3"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="0" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Button x:Name="AddPartButton" Grid.Row="0" Visibility="Collapsed" Click="AddPartButton_OnClick" />
                    <Button x:Name="DeletePartButton" Grid.Row="0" Visibility="Collapsed" Click="DeletePartButton_OnClick" />

                    <ListBox x:Name="PartsList"
                             Grid.Row="1"
                             Background="Transparent"
                             BorderThickness="0"
                             SelectionChanged="PartsList_OnSelectionChanged"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Margin" Value="0,0,0,8" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="ItemBorder"
                                                    Background="#FFFFFF"
                                                    BorderBrush="#E3E7E5"
                                                    BorderThickness="1"
                                                    CornerRadius="8">
                                                <ContentPresenter />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#7CA58D" />
                                                    <Setter TargetName="ItemBorder" Property="BorderThickness" Value="2" />
                                                    <Setter TargetName="ItemBorder" Property="Background" Value="#FAFCFB" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="10,8,10,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="48" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="40" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0"
                                                Margin="0,2,10,0">
                                        <Border Width="36"
                                                Height="28"
                                                HorizontalAlignment="Center"
                                                Margin="0,2,0,0"
                                                Background="{Binding SpeakerAccentBrush}"
                                                CornerRadius="8">
                                            <TextBlock VerticalAlignment="Center"
                                                       HorizontalAlignment="Center"
                                                       Foreground="White"
                                                       FontWeight="SemiBold"
                                                       Text="{Binding Order, StringFormat={}{0:00}}" />
                                        </Border>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1">
                                        <DockPanel Margin="0,0,0,6" LastChildFill="False">
                                            <Border DockPanel.Dock="Left"
                                                    HorizontalAlignment="Left"
                                                    Padding="10,4"
                                                    Background="{Binding SpeakerAccentBrush}"
                                                    CornerRadius="12">
                                                <TextBlock Foreground="White"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"
                                                           Text="{Binding SpeakerTag}" />
                                            </Border>
                                            <Border DockPanel.Dock="Right"
                                                    Margin="8,0,0,0"
                                                    Padding="10,4"
                                                    Background="#EDF2EF"
                                                    BorderBrush="#D7E0DB"
                                                    BorderThickness="1"
                                                    CornerRadius="12">
                                                <TextBlock Foreground="#4D5A54"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"
                                                           Text="{Binding VoiceDisplayLabel}" />
                                            </Border>
                                        </DockPanel>
                                        <TextBox Style="{StaticResource PartTextEditorStyle}"
                                                 BorderBrush="{Binding SpeakerAccentBrush}"
                                                 Tag="{Binding}"
                                                 Text="{Binding Text, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 PreviewKeyDown="PartTextEditor_OnPreviewKeyDown"
                                                 GotKeyboardFocus="PartTextEditor_OnGotKeyboardFocus"
                                                 Loaded="PartTextEditor_OnLoaded"
                                                 Unloaded="PartTextEditor_OnUnloaded" />
                                    </StackPanel>

                                    <Button Grid.Column="2"
                                            Style="{StaticResource PrepIconButtonStyle}"
                                            VerticalAlignment="Top"
                                            HorizontalAlignment="Right"
                                            Margin="0,0,2,0"
                                            Content="&#xE74D;"
                                            Tag="{Binding}"
                                            Click="DeletePartForItemButton_OnClick" />
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <Border Grid.Column="1"
                    Background="White"
                    BorderBrush="#E1E6E3"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="12">
                <Grid IsEnabled="{Binding ElementName=PartsList, Path=HasItems}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <TextBlock Foreground="#6A7871" FontSize="12" Text="Selected Part" />
                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                            <Border Width="40"
                                    Height="28"
                                    Background="{Binding ElementName=PartsList, Path=SelectedItem.SpeakerAccentBrush}"
                                    CornerRadius="8">
                                <TextBlock VerticalAlignment="Center"
                                           HorizontalAlignment="Center"
                                           Foreground="White"
                                           FontWeight="SemiBold"
                                           Text="{Binding ElementName=PartsList, Path=SelectedItem.Order, StringFormat={}{0:00}}" />
                            </Border>
                            <Border Margin="10,0,0,0"
                                    Padding="10,4"
                                    Background="{Binding ElementName=PartsList, Path=SelectedItem.SpeakerAccentBrush}"
                                    CornerRadius="12">
                                <TextBlock Foreground="White"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Text="{Binding ElementName=PartsList, Path=SelectedItem.SpeakerTag}" />
                            </Border>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Margin="0,16,0,0">
                        <TextBlock Foreground="#6A7871" FontSize="12" Text="Voice" />
                        <ComboBox Height="34"
                                  Margin="0,6,0,0"
                                  ItemsSource="{Binding ElementName=RootWindow, Path=VoiceChoices}"
                                  DisplayMemberPath="Display"
                                  SelectedValuePath="Path"
                                  SelectedValue="{Binding ElementName=PartsList, Path=SelectedItem.VoicePath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  SelectionChanged="InspectorVoiceCombo_OnSelectionChanged" />

                        <TextBlock Margin="0,12,0,0" Foreground="#6A7871" FontSize="12" Text="Recent Voices" />
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      MaxHeight="132"
                                      Margin="0,6,0,0"
                                      ToolTip="Recent voice history. Scroll to see older entries.">
                            <ItemsControl ItemsSource="{Binding ElementName=PartsList, Path=SelectedItem.RecentVoiceChoices}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Margin="0,0,0,6"
                                                HorizontalAlignment="Left"
                                                Style="{StaticResource PrepChipButtonStyle}"
                                                Content="{Binding Display}"
                                                CommandParameter="{Binding}"
                                                Click="InspectorRecentVoiceButton_OnClick" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </StackPanel>

                    <StackPanel Grid.Row="2"
                                Margin="0,16,0,0"
                                Orientation="Horizontal">
                        <Button MinWidth="120"
                                Margin="0,0,8,0"
                                Content="+ Add Below"
                                Style="{StaticResource PrepSecondaryButtonStyle}"
                                Click="InspectorAddPartButton_OnClick" />
                        <Button MinWidth="100"
                                Content="Split Here"
                                Style="{StaticResource PrepSecondaryButtonStyle}"
                                Click="InspectorSplitButton_OnClick" />
                    </StackPanel>

                    <StackPanel Grid.Row="3"
                                Margin="0,16,0,0"
                                Orientation="Vertical"
                                Visibility="{Binding ElementName=RootWindow, Path=InstructionEditorVisibility}">
                        <TextBlock Foreground="#6A7871" FontSize="12" Text="Instruction" />
                        <CheckBox Margin="0,8,0,0"
                                  Content="Locked"
                                  IsChecked="{Binding ElementName=PartsList, Path=SelectedItem.Locked, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBox Margin="0,6,0,0"
                                 MinHeight="58"
                                 Padding="10,8"
                                 Background="#FAFCFB"
                                 BorderBrush="#D7E0DB"
                                 BorderThickness="1"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 Text="{Binding ElementName=PartsList, Path=SelectedItem.Instruction, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>

                    <StackPanel Grid.Row="4"
                                Margin="0,16,0,0"
                                Orientation="Vertical"
                                Visibility="{Binding ElementName=RootWindow, Path=ManualSfxControlsVisibility}">
                        <CheckBox Content="Disable auto SFX detection"
                                  IsChecked="{Binding ElementName=PartsList, Path=SelectedItem.DisableAutoSfxDetection, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <StackPanel Margin="0,8,0,0"
                                    Orientation="Vertical"
                                    Visibility="{Binding ElementName=PartsList, Path=SelectedItem.ManualSfxEditorVisibility}">
                            <TextBlock Foreground="#6A7871" FontSize="12" Text="Sound Effect" />
                            <TextBox Margin="0,6,0,0"
                                     MinHeight="84"
                                     Padding="10,8"
                                     Background="#FAFCFB"
                                     BorderBrush="#D7E0DB"
                                     BorderThickness="1"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     Text="{Binding ElementName=PartsList, Path=SelectedItem.SoundEffectPrompt, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
        <Grid Grid.Row="2" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="FooterText" VerticalAlignment="Center" Foreground="#52615A" />
            <Button x:Name="SaveButton" Grid.Column="1" Margin="0,0,8,0" MinWidth="120" Style="{StaticResource PrepSecondaryButtonStyle}" Content="Save" Click="SaveButton_OnClick" />
            <Button x:Name="SaveCloseButton" Grid.Column="2" MinWidth="140" Style="{StaticResource PrepSecondaryButtonStyle}" Content="Save &amp; Close" Click="SaveCloseButton_OnClick" />
        </Grid>
    </Grid>
</Window>
