<Window x:Class="AudiobookCreator.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AudiobookCreator.UI"
        mc:Ignorable="d"
        Title="Audiobook Creator"
        Height="820"
        Width="1280"
        MinHeight="760"
        MinWidth="1160"
        Background="#F4F6F5"
        FontFamily="Segoe UI"
        FontSize="13"
        TextOptions.TextFormattingMode="Display"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <Window.Resources>
        <local:FileNameOnlyConverter x:Key="FileNameOnlyConverter" />
        <SolidColorBrush x:Key="PrimaryGreen" Color="#4F7D63" />
        <SolidColorBrush x:Key="SecondaryBg" Color="#E6ECE9" />

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#E1E6E3" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="20" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.04" Color="#000000" />
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="42" />
            <Setter Property="Background" Value="{StaticResource PrimaryGreen}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryGreen}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#436C55" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#436C55" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.62" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="34" />
            <Setter Property="Background" Value="{StaticResource SecondaryBg}" />
            <Setter Property="BorderBrush" Value="#D5DDD8" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#2F3A34" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#D8E2DD" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.62" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TopBarButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="Height" Value="38" />
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="Background" Value="#F3F7F5" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#E3EBE7" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.62" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TopBarButtonLeftStyle" TargetType="Button" BasedOn="{StaticResource TopBarButtonStyle}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8,0,0,8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#E3EBE7" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.62" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TopBarButtonRightStyle" TargetType="Button" BasedOn="{StaticResource TopBarButtonStyle}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="0,8,8,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#E3EBE7" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.62" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="Background" Value="#C95C5C" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#C95C5C" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#B44F4F" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#B44F4F" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.62" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FlatIconButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="24" />
            <Setter Property="Height" Value="24" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="QueueActionIconButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="Width" Value="36" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="Normal" />
            <Style.Triggers>
                <Trigger Property="Content" Value="">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Setter Property="IsHitTestVisible" Value="False" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="QueueProgressBarStyle" TargetType="ProgressBar">
            <Setter Property="Height" Value="6" />
            <Setter Property="Foreground" Value="#4F7D63" />
            <Setter Property="Background" Value="#E3E8E5" />
        </Style>

        <Style x:Key="GreenCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#2F3A34" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Grid Width="14" Height="14" VerticalAlignment="Center">
                                <Border x:Name="CheckBorder"
                                        Width="14"
                                        Height="14"
                                        CornerRadius="2"
                                        BorderBrush="#BECAC3"
                                        BorderThickness="1"
                                        Background="White" />
                                <Path x:Name="CheckGlyph"
                                      Data="M 2 7 L 5.2 10.2 L 12 3.2"
                                      Stroke="White"
                                      StrokeThickness="1.8"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round"
                                      Visibility="Collapsed" />
                            </Grid>
                            <ContentPresenter Margin="8,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckBorder" Property="Background" Value="#4F7D63" />
                                <Setter TargetName="CheckBorder" Property="BorderBrush" Value="#4F7D63" />
                                <Setter TargetName="CheckGlyph" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.65" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" BorderBrush="#E1E6E3" BorderThickness="0,0,0,1">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#5F8F76" Offset="0" />
                    <GradientStop Color="#4F7D63" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>
            <Grid Margin="24,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Image x:Name="HeaderIcon" Width="34" Height="34" Margin="0,0,10,0" />
                    <TextBlock Text="Audiobook Creator" Foreground="White" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" />
                </StackPanel>

                <Border Grid.Column="1"
                        Height="38"
                        MinWidth="560"
                        VerticalAlignment="Center"
                        Margin="0"
                        CornerRadius="8"
                        Background="#F3F7F5"
                        BorderBrush="#D3DBD7"
                        BorderThickness="1"
                        Padding="0">
                    <Grid VerticalAlignment="Stretch">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="1" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="1" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="1" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button x:Name="NewProjectButton" Grid.Column="0" Content="New Project" Style="{StaticResource TopBarButtonLeftStyle}" Click="NewProjectButton_OnClick" />
                        <Border Grid.Column="1" Width="1" Margin="0" Background="#DDE4E0" HorizontalAlignment="Center" />
                        <Button x:Name="OpenProjectButton" Grid.Column="2" Content="Open Project" Style="{StaticResource TopBarButtonStyle}" Click="OpenProjectButton_OnClick" />
                        <Border Grid.Column="3" Width="1" Margin="0" Background="#DDE4E0" HorizontalAlignment="Center" />
                        <Button x:Name="SaveProjectButton" Grid.Column="4" Content="Save" Style="{StaticResource TopBarButtonStyle}" Click="SaveProjectButton_OnClick" />
                        <Border Grid.Column="5" Width="1" Margin="0" Background="#DDE4E0" HorizontalAlignment="Center" />
                        <Button x:Name="SettingsButton" Grid.Column="6" Content="Settings" Style="{StaticResource TopBarButtonRightStyle}" Click="SettingsButton_OnClick" />
                    </Grid>
                </Border>

                <Button Grid.Column="2"
                        Margin="12,0,0,0"
                        Width="34"
                        Height="34"
                        VerticalAlignment="Center"
                        Content="X"
                        FontSize="18"
                        Foreground="White"
                        Background="Transparent"
                        BorderThickness="0"
                        Click="CloseButton_OnClick" />
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="24,24,24,12">
            <TabControl x:Name="MainTabControl" BorderThickness="0" Background="Transparent">
                <TabItem Header="Create Audiobook">
                    <Grid Margin="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="1.08*" />
                <RowDefinition Height="20" />
                <RowDefinition Height="0.92*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.2*" />
                <ColumnDefinition Width="20" />
                <ColumnDefinition Width="0.9*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource CardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="0" />
                            <RowDefinition Height="0" />
                        </Grid.RowDefinitions>

                        <TextBlock Text="Project Details" FontSize="16" FontWeight="SemiBold" Foreground="#1F2723" />

                    <Grid Grid.Row="1" Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ComboBox x:Name="ProjectSelectorCombo" Height="32" VerticalContentAlignment="Center" SelectionChanged="ProjectSelectorCombo_OnSelectionChanged" />
                        <Button x:Name="InlineNewProjectButton" Grid.Column="1" Margin="8,0,0,0" MinWidth="80" Padding="14,0" Content="New" Style="{StaticResource SecondaryButtonStyle}" Click="NewProjectButton_OnClick" />
                    </Grid>

                    <Separator Grid.Row="2" Margin="0,8,0,8" Background="#E1E6E3" />

                    <TextBlock Grid.Row="3" Text="Input Files" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <Grid Grid.Row="4" Margin="0,6,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button x:Name="AddFilesButton"
                                Grid.Column="0"
                                MinWidth="92"
                                Height="30"
                                FontSize="12"
                                Padding="10,0"
                                Content="Add Files"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Click="AddFilesButton_OnClick"
                                HorizontalAlignment="Left" />

                        <Button x:Name="ClearInputFilesButton"
                                Grid.Column="1"
                                Margin="8,0,0,0"
                                MinWidth="80"
                                Height="30"
                                FontSize="12"
                                Padding="10,0"
                                Content="Clear All"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Click="ClearAllInputFilesButton_OnClick"
                                HorizontalAlignment="Left" />

                        <CheckBox x:Name="UseAllInputFilesCheckBox"
                                  Grid.Column="4"
                                  Content="Use all imported files"
                                  VerticalAlignment="Center"
                                  Style="{StaticResource GreenCheckBoxStyle}"
                                  Checked="UseAllInputFilesCheckBox_OnChanged"
                                  Unchecked="UseAllInputFilesCheckBox_OnChanged" />
                    </Grid>

                    <ListBox x:Name="InputFilesList"
                             Grid.Row="5"
                             Margin="0,6,0,0"
                             MinHeight="120"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.CanContentScroll="True"
                             BorderBrush="#E1E6E3"
                             BorderThickness="1">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Margin" Value="0" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Background" Value="White" />
                                <Setter Property="BorderThickness" Value="0,0,0,1" />
                                <Setter Property="BorderBrush" Value="#E9EEEB" />
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#F0F3F1" />
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#F0F3F1" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Height="42" Margin="8,0,6,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="24" />
                                        <ColumnDefinition Width="20" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="24" />
                                    </Grid.ColumnDefinitions>
                                    <CheckBox Grid.Column="0"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Center"
                                              IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                              Checked="InputFileSelectionCheckBox_OnChanged"
                                              Unchecked="InputFileSelectionCheckBox_OnChanged">
                                        <CheckBox.Style>
                                            <Style TargetType="CheckBox" BasedOn="{StaticResource GreenCheckBoxStyle}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsChecked, ElementName=UseAllInputFilesCheckBox}" Value="True">
                                                        <Setter Property="IsEnabled" Value="False" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </CheckBox.Style>
                                    </CheckBox>
                                    <TextBlock Grid.Column="1"
                                               Text="&#xE160;"
                                               FontFamily="Segoe MDL2 Assets"
                                               Foreground="#82908A"
                                               FontSize="14"
                                               VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="3"
                                               Text="{Binding DisplayName}"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis" />
                                    <Button Grid.Column="4"
                                            Content="Prepare"
                                            Height="24"
                                            Width="74"
                                            FontSize="11"
                                            Padding="8,0"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Tag="{Binding FullPath}"
                                            Click="PrepareInputFileButton_OnClick"
                                            Visibility="{Binding PrepareButtonVisibility}" />
                                    <Button
                                            Width="22"
                                            Height="22"
                                            Margin="0,0,0,0"
                                            Content="&#xE74D;"
                                            FontFamily="Segoe MDL2 Assets"
                                            Foreground="#7C8782"
                                            Padding="0"
                                            Grid.Column="6"
                                            Tag="{Binding FullPath}"
                                            Click="RemoveInputFileButton_OnClick"
                                            Style="{StaticResource FlatIconButtonStyle}" />
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <TextBlock Grid.Row="7" Margin="0,12,0,0" Text="Output Folder" FontSize="13" Visibility="Collapsed" />
                    <Grid Grid.Row="8" Margin="0,6,0,0" Visibility="Collapsed">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="OutputFolderTextBox" Height="36" VerticalContentAlignment="Center" LostFocus="OutputFolderTextBox_OnLostFocus" />
                        <Button x:Name="BrowseOutputButton" Grid.Column="1" Content="Browse" Style="{StaticResource SecondaryButtonStyle}" Click="BrowseOutputButton_OnClick" />
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Row="0" Grid.Column="2" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="Voice Settings" FontSize="16" FontWeight="SemiBold" Foreground="#1F2723" />
                    <TextBlock Grid.Row="1" Margin="0,10,0,0" Text="Narrator Voice" />
                    <Grid Grid.Row="2" Margin="0,6,0,0">
                        <ComboBox x:Name="VoiceCombo" Height="36" VerticalContentAlignment="Center" SelectionChanged="VoiceCombo_OnSelectionChanged">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center" />
                                        <TextBlock Text=" ✓" VerticalAlignment="Center" Foreground="#4F7D63" Margin="6,0,0,0">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ShowRefCheckmark}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </Grid>
                    <StackPanel Grid.Row="3" Margin="0,10,0,0">
                                <Button x:Name="PlaySampleButton" MinWidth="136" Padding="18,0" HorizontalAlignment="Left" Content="Play Sample" Style="{StaticResource SecondaryButtonStyle}" Click="PlaySampleButton_OnClick" />
                        <TextBlock x:Name="VoiceModelNoteText"
                                   Margin="0,8,0,0"
                                   Foreground="#5B6661"
                                   FontSize="12"
                                   TextWrapping="Wrap"
                                   Visibility="Collapsed"
                                   Text="" />
                    </StackPanel>
                    <Separator Grid.Row="4" Margin="0,12,0,12" Background="#E1E6E3" />
                    <TextBlock x:Name="StylePresetLabel" Grid.Row="5" Text="Speaking Style" />
                    <ComboBox x:Name="StylePresetCombo" Grid.Row="5" Margin="0,24,0,0" Height="36" VerticalContentAlignment="Center" SelectionChanged="StylePresetCombo_OnSelectionChanged">
                        <ComboBoxItem IsSelected="True">Standard</ComboBoxItem>
                        <ComboBoxItem>Expressive</ComboBoxItem>
                        <ComboBoxItem>Calm</ComboBoxItem>
                    </ComboBox>
                    <Grid Grid.Row="6" Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Speech Speed" VerticalAlignment="Center" />
                        <Slider x:Name="SpeedSlider" Grid.Column="1" Margin="12,0,12,0" Minimum="0.5" Maximum="1.5" TickFrequency="0.1" Value="1.0" ValueChanged="SpeedSlider_OnValueChanged" />
                        <TextBlock x:Name="SpeedLabel" Grid.Column="2" Text="1.0x" VerticalAlignment="Center" />
                    </Grid>
                    <Grid Grid.Row="7" Margin="0,10,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock x:Name="ModelSummaryText" Text="AI Model: chatterbox-ONNX" />
                        <TextBlock x:Name="ModelControlsSummaryText" Grid.Row="1" Margin="0,6,0,0" Foreground="#5B6661" FontSize="12" Text="Chunk: auto" />
                        <Grid Grid.Row="2" Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
