<Window x:Class="AudiobookCreator.UI.AudioEnhancePrepWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Prepare Audio Enhancement"
        Width="1280"
        Height="820"
        MinWidth="980"
        MinHeight="640"
        WindowStartupLocation="CenterOwner"
        Background="#F5F7F6">
    <Window.Resources>
        <Style x:Key="PrepCardStyle" TargetType="Border">
            <Setter Property="BorderBrush" Value="#D9E3DE" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Background" Value="#FBFCFB" />
        </Style>
        <Style x:Key="PrepLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#66726D" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style x:Key="PrepFieldStyle" TargetType="TextBox">
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#C8D3CD" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style x:Key="PrepMultilineFieldStyle" TargetType="TextBox" BasedOn="{StaticResource PrepFieldStyle}">
            <Setter Property="Height" Value="Auto" />
            <Setter Property="MinHeight" Value="70" />
            <Setter Property="VerticalContentAlignment" Value="Top" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="AcceptsReturn" Value="True" />
            <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
        </Style>
        <Style x:Key="PrepButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="Background" Value="#E3E9E5" />
            <Setter Property="Foreground" Value="#243029" />
            <Setter Property="BorderBrush" Value="#CBD5CF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.92" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.62" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="PrepPrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrepButtonStyle}">
            <Setter Property="Background" Value="#5C8A6A" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#4F7D63" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style x:Key="PrepDangerButtonStyle" TargetType="Button" BasedOn="{StaticResource PrepButtonStyle}">
            <Setter Property="Background" Value="#F7E3E0" />
            <Setter Property="Foreground" Value="#8C3A32" />
            <Setter Property="BorderBrush" Value="#E1B7B2" />
        </Style>
        <Style x:Key="CueChipTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </Window.Resources>
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock x:Name="SourceFileText"
                       FontSize="20"
                       FontWeight="SemiBold"
                       Foreground="#1F2723"
                       Text="Prepare Audio Enhancement" />
            <TextBlock Margin="0,4,0,0"
                       Foreground="#5B6661"
                       TextWrapping="Wrap"
                       Text="Set exact timing segments for background ambience and sound effects. This window is only the preparation phase. AudioX generation happens later when you run enhancement." />
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,12,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="1.1*" />
                <RowDefinition Height="12" />
                <RowDefinition Height="0.9*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{StaticResource PrepCardStyle}">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Waveform Timeline"
                                   FontWeight="SemiBold"
                                   Foreground="#1F2723"
                                   VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1"
                                   Margin="10,0,0,0"
                                   Foreground="#68746E"
                                   VerticalAlignment="Center"
                                   Text="Drag inside a blue segment to move it. Drag dark edge handles to resize. Drag the orange marker line to place the sound effect hit." />
                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button x:Name="PlayButton"
                                    Width="72"
                                    Margin="0,0,8,0"
                                    Style="{StaticResource PrepButtonStyle}"
                                    Content="Play"
                                    Click="PlayButton_OnClick" />
                            <Button x:Name="StopButton"
                                    Width="72"
                                    Margin="0,0,10,0"
                                    Style="{StaticResource PrepButtonStyle}"
                                    Content="Stop"
                                    Click="StopButton_OnClick" />
                            <TextBlock x:Name="PlaybackTimeText"
                                       Margin="0,0,10,0"
                                       VerticalAlignment="Center"
                                       Foreground="#5B6661"
                                       Text="00:00 / 00:00" />
                            <TextBlock Margin="0,0,6,0" VerticalAlignment="Center" Foreground="#5B6661" Text="Zoom" />
                            <Slider x:Name="WaveZoomSlider"
                                    Width="120"
                                    Minimum="0.5"
                                    Maximum="4"
                                    Value="1"
                                    SmallChange="0.1"
                                    LargeChange="0.25"
                                    ValueChanged="WaveZoomSlider_OnValueChanged" />
                        </StackPanel>
                    </Grid>
                    <Border Grid.Row="1" Margin="0,10,0,0" BorderBrush="#DCE5E0" BorderThickness="1" Background="#FDFEFE">
                        <ScrollViewer x:Name="WaveScrollViewer"
                                      HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Disabled"
                                      CanContentScroll="False">
                            <Canvas x:Name="WaveformCanvas" Height="280" Background="#FDFEFE" />
                        </ScrollViewer>
                    </Border>
                    <Grid Grid.Row="2" Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Foreground="#6A7670"
                                   TextWrapping="Wrap"
                                   Text="This is the main editor. Drag the segment block to move it, drag the dark side handles to resize it, and drag the marker line for the sound effect. The panel below is only for exact values and prompt text." />
                        <Border Grid.Column="1"
                                Margin="10,0,0,0"
                                Padding="8,3"
                                Background="#D7E6F7"
                                BorderBrush="#8AAFD5"
                                BorderThickness="1"
                                CornerRadius="10">
                            <TextBlock Foreground="#2A5E93" FontSize="11" Text="Background Ambience" />
                        </Border>
                        <Border Grid.Column="2"
                                Margin="8,0,0,0"
                                Padding="8,3"
                                Background="#FBE6D0"
                                BorderBrush="#DB9647"
                                BorderThickness="1"
                                CornerRadius="10">
                            <TextBlock Foreground="#A35C16" FontSize="11" Text="Sound Effect Marker" />
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Row="2" Style="{StaticResource PrepCardStyle}">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock FontWeight="SemiBold" Foreground="#1F2723" Text="Timeline Segments" />
                            <TextBlock Margin="0,4,0,0"
                                       Foreground="#68746E"
                                       Text="Edit exact timing, transcript text, background ambience, and single sound effect here." />
                        </StackPanel>
                        <Button x:Name="ImportSubtitleButton"
                                Grid.Column="1"
                                Margin="12,0,0,0"
                                Width="112"
                                Style="{StaticResource PrepButtonStyle}"
                                Content="Import SRT/ASS"
                                Click="ImportSubtitleButton_OnClick" />
                        <Button x:Name="AddSegmentButton"
                                Grid.Column="2"
                                Margin="8,0,0,0"
                                Width="92"
                                Style="{StaticResource PrepButtonStyle}"
                                Content="Add Segment"
                                Click="AddSegmentButton_OnClick" />
                        <Button x:Name="DeleteSegmentButton"
                                Grid.Column="3"
                                Margin="8,0,0,0"
                                Width="96"
                                Style="{StaticResource PrepDangerButtonStyle}"
                                Content="Delete Segment"
                                Click="DeleteSegmentButton_OnClick" />
                        <Button x:Name="ClearSegmentsButton"
                                Grid.Column="4"
                                Margin="8,0,0,0"
                                Width="88"
                                Style="{StaticResource PrepButtonStyle}"
                                Content="Clear"
                                Click="ClearSegmentsButton_OnClick" />
                    </Grid>
                    <Border Grid.Row="1"
                            Margin="0,10,0,0"
                            BorderBrush="#D7E0DB"
                            BorderThickness="1"
                            Background="#FFFFFF">
                        <ListBox x:Name="SegmentsGrid"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 SelectionMode="Single"
                                 SelectionChanged="SegmentsGrid_OnSelectionChanged">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="Margin" Value="0" />
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="VerticalContentAlignment" Value="Stretch" />
                                    <Setter Property="BorderThickness" Value="0" />
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Border Background="{TemplateBinding Background}"
                                                        BorderThickness="0"
                                                        SnapsToDevicePixels="True">
                                                    <ContentPresenter />
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border x:Name="CardBorder"
                                            Margin="10,10,10,0"
                                            Padding="14"
                                            Background="#FCFDFC"
                                            BorderBrush="#D7E0DB"
                                            BorderThickness="1"
                                            CornerRadius="10">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <Grid Grid.Row="0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                                <CheckBox IsChecked="{Binding Enabled, Mode=TwoWay}" VerticalAlignment="Center" />
                                                <TextBlock Margin="8,0,0,0"
                                                           VerticalAlignment="Center"
                                                           FontSize="13"
                                                           FontWeight="SemiBold"
                                                           Foreground="#1F2723"
                                                           Text="{Binding Order, StringFormat=Part {0:00}}" />
                                            </StackPanel>
                                                <Button Grid.Column="1"
                                                        Margin="0,0,8,0"
                                                        Width="96"
                                                        Style="{StaticResource PrepButtonStyle}"
                                                        Content="+ Add Below"
                                                        Tag="{Binding}"
                                                        Click="AddSegmentAfterButton_OnClick" />
                                                <Button Grid.Column="2"
                                                        Width="76"
                                                        Style="{StaticResource PrepDangerButtonStyle}"
                                                        Content="Delete"
                                                        Tag="{Binding}"
                                                        Click="DeleteSegmentRowButton_OnClick" />
                                            </Grid>

                                            <StackPanel Grid.Row="1" Margin="0,12,0,0">
                                                <TextBlock Style="{StaticResource PrepLabelStyle}" Text="Transcript / Segment Text" />
                                                <TextBox Margin="0,6,0,0"
                                                         Style="{StaticResource PrepMultilineFieldStyle}"
                                                         Text="{Binding Text, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            </StackPanel>

                                            <Grid Grid.Row="2"
                                                  Margin="0,12,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="12" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Style="{StaticResource PrepLabelStyle}" Text="Start Time (s)" />
                                                    <TextBox Margin="0,6,0,0"
                                                             Style="{StaticResource PrepFieldStyle}"
                                                             Text="{Binding StartSeconds, Mode=TwoWay, StringFormat=0.00, UpdateSourceTrigger=PropertyChanged}" />
                                                </StackPanel>
                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Style="{StaticResource PrepLabelStyle}" Text="End Time (s)" />
                                                    <TextBox Margin="0,6,0,0"
                                                             Style="{StaticResource PrepFieldStyle}"
                                                             Text="{Binding EndSeconds, Mode=TwoWay, StringFormat=0.00, UpdateSourceTrigger=PropertyChanged}" />
                                                </StackPanel>
                                            </Grid>

                                            <Grid Grid.Row="3" Margin="0,12,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="12" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Style="{StaticResource PrepLabelStyle}" Text="Sound Effect Time (s)" />
                                                    <TextBox Margin="0,6,0,0"
                                                             Style="{StaticResource PrepFieldStyle}"
                                                             Text="{Binding OneShotSeconds, Mode=TwoWay, StringFormat=0.00, UpdateSourceTrigger=PropertyChanged}" />
                                                </StackPanel>
                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Style="{StaticResource PrepLabelStyle}" Text="Intensity" />
                                                    <TextBox Margin="0,6,0,0"
                                                             Style="{StaticResource PrepFieldStyle}"
                                                             Text="{Binding Intensity, Mode=TwoWay, StringFormat=0.00, UpdateSourceTrigger=PropertyChanged}" />
                                                </StackPanel>
                                            </Grid>

                                            <Border Grid.Row="4"
                                                    Margin="0,12,0,0"
                                                    Padding="10,8"
                                                    Background="#F5F8F6"
                                                    BorderBrush="#DFE7E2"
                                                    BorderThickness="1"
                                                    CornerRadius="8">
                                                <StackPanel>
                                                    <TextBlock Foreground="#55635C" FontSize="11" Text="Background Ambience = low continuous background across this whole segment." />
                                                    <TextBlock Margin="0,4,0,0" Foreground="#55635C" FontSize="11" Text="Sound Effect = a single short hit placed once at Sound Effect Time." />
                                                </StackPanel>
                                            </Border>

                                            <StackPanel Grid.Row="5" Margin="0,12,0,0">
                                                <StackPanel Orientation="Horizontal">
                                                    <Border Width="12"
                                                            Height="12"
                                                            Margin="0,0,6,0"
                                                            Background="#D7E6F7"
                                                            BorderBrush="#8AAFD5"
                                                            BorderThickness="1"
                                                            CornerRadius="6" />
                                                    <TextBlock Style="{StaticResource CueChipTextStyle}"
                                                               Foreground="#2A5E93"
                                                               Text="Background Ambience" />
                                                </StackPanel>
                                                <TextBox Margin="0,6,0,0"
                                                         Style="{StaticResource PrepFieldStyle}"
                                                         Text="{Binding AmbiencePrompt, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            </StackPanel>

                                            <StackPanel Grid.Row="6" Margin="0,12,0,0">
                                                <StackPanel Orientation="Horizontal">
                                                    <Border Width="12"
                                                            Height="12"
                                                            Margin="0,0,6,0"
                                                            Background="#FBE6D0"
                                                            BorderBrush="#DB9647"
                                                            BorderThickness="1"
                                                            CornerRadius="6" />
                                                    <TextBlock Style="{StaticResource CueChipTextStyle}"
                                                               Foreground="#A35C16"
                                                               Text="Sound Effect" />
                                                </StackPanel>
                                                <TextBox Margin="0,6,0,0"
                                                         Style="{StaticResource PrepFieldStyle}"
                                                         Text="{Binding OneShotPrompt, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="True">
                                            <Setter TargetName="CardBorder" Property="BorderBrush" Value="#4F7D63" />
                                            <Setter TargetName="CardBorder" Property="BorderThickness" Value="2" />
                                            <Setter TargetName="CardBorder" Property="Background" Value="#F4FAF6" />
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Row="2" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="StatusText"
                       VerticalAlignment="Center"
                       Foreground="#5B6661"
                       Text="Ready." />
            <Button Grid.Column="1"
                    Margin="0,0,10,0"
                    Width="110"
                    Style="{StaticResource PrepButtonStyle}"
                    Content="Cancel"
                    Click="CancelButton_OnClick" />
            <Button Grid.Column="2"
                    Width="140"
                    Style="{StaticResource PrepPrimaryButtonStyle}"
                    Content="Save &amp; Close"
                    Click="SaveButton_OnClick" />
        </Grid>
    </Grid>
</Window>
